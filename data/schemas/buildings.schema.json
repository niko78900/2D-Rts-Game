{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "minProperties": 1,
  "additionalProperties": {
    "type": "object",
    "required": ["display_name", "stats", "cost", "functions", "animations"],
    "properties": {
      "display_name": {"type": "string", "minLength": 1},
      "stats": {
        "type": "object",
        "required": ["hp", "footprint_px", "build_time_ms"],
        "properties": {
          "hp": {"type": "integer", "minimum": 1},
          "footprint_px": {
            "type": "array",
            "prefixItems": [{"type": "integer", "minimum": 1}, {"type": "integer", "minimum": 1}],
            "minItems": 2,
            "maxItems": 2
          },
          "build_time_ms": {"type": "integer", "minimum": 0}
        },
        "additionalProperties": false
      },
      "cost": {"$ref": "#/$defs/cost"},
      "functions": {"type": "object"},
      "animations": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 1}}
    },
    "additionalProperties": false
  },
  "$defs": {
    "cost": {
      "type": "object",
      "required": ["wood", "food", "stone", "iron", "gold"],
      "properties": {
        "wood": {"type": "integer", "minimum": 0},
        "food": {"type": "integer", "minimum": 0},
        "stone": {"type": "integer", "minimum": 0},
        "iron": {"type": "integer", "minimum": 0},
        "gold": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    }
  }
}
